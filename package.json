{
  "name": "octra-vitals",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.8.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/*.test.js",
    "canonical:verify": "npm run build && node dist/scripts/verify-canonical-json.js",
    "dev": "npm run build && node dist/gateway/node-gateway/server.js",
    "start": "node dist/gateway/node-gateway/server.js",
    "snapshot": "npm run build && node dist/scripts/build-snapshot.js",
    "snapshot:sample": "npm run build && node dist/scripts/build-snapshot.js --out app/latest_snapshot.sample.json",
    "program:compile": "npm run build && node dist/scripts/compile-program.js",
    "program:verify": "npm run build && node dist/scripts/verify-program-artifacts.js",
    "program-circle:compile": "npm run build && node dist/scripts/compile-programmed-circle.js",
    "program-circle:verify": "npm run build && node dist/scripts/verify-programmed-circle-artifacts.js",
    "program:deploy": "npm run program:compile && npm run program:verify && node dist/scripts/deploy-program.js",
    "program:verify-source": "npm run build && node dist/scripts/verify-deployed-program-source.js",
    "manifest:sync": "npm run build && node dist/scripts/sync-app-manifest.js",
    "producer:audit": "npm run build && node dist/scripts/build-producer-audit-manifest.js",
    "producer:audit:dist": "node dist/scripts/build-producer-audit-manifest.js",
    "program:read-latest": "npm run build && node dist/scripts/read-program-snapshot.js",
    "program:record-call": "npm run build && node dist/scripts/build-record-snapshot-call.js",
    "program:submit-snapshot": "npm run build && node dist/scripts/submit-snapshot.js",
    "program:update": "npm run build && node dist/scripts/run-snapshot-update.js",
    "snapshot:dist": "node dist/scripts/build-snapshot.js",
    "program:record-call:dist": "node dist/scripts/build-record-snapshot-call.js",
    "program:submit-snapshot:dist": "node dist/scripts/submit-snapshot.js",
    "program:update:dist": "node dist/scripts/run-snapshot-update.js",
    "watch:updater": "npm run build && node dist/scripts/watch-updater.js",
    "watch:updater:dist": "node dist/scripts/watch-updater.js",
    "traffic:summary": "npm run build && node dist/scripts/summarize-traffic.js",
    "traffic:summary:dist": "node dist/scripts/summarize-traffic.js",
    "snapshot-runs:summary": "npm run build && node dist/scripts/summarize-snapshot-runs.js",
    "snapshot-runs:summary:dist": "node dist/scripts/summarize-snapshot-runs.js",
    "notify:operator": "npm run build && node dist/scripts/notify-operator.js",
    "notify:operator:dist": "node dist/scripts/notify-operator.js",
    "release:plan": "bash deploy/mainnet/plan-release.sh",
    "circle:release": "npm run build && node dist/scripts/build-producer-audit-manifest.js && node dist/scripts/build-site-circle-release.js",
    "circle:deploy": "npm run build && node dist/scripts/build-producer-audit-manifest.js && node dist/scripts/deploy-site-circle.js",
    "circle:verify": "npm run build && node dist/scripts/build-producer-audit-manifest.js && node dist/scripts/deploy-site-circle.js --dry-run",
    "circle:programmed:deploy": "npm run program-circle:compile && npm run program-circle:verify && node dist/scripts/deploy-programmed-circle.js",
    "circle:programmed:deploy:dist": "node dist/scripts/verify-programmed-circle-artifacts.js && node dist/scripts/deploy-programmed-circle.js",
    "native:verify": "npm run test && npm run canonical:verify && npm run program:compile && npm run program:verify && npm run program-circle:compile && npm run program-circle:verify && npm run circle:release && npm run circle:verify"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "typescript": "^6.0.3"
  }
}
